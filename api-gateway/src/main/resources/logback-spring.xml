<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logs pipeline (ADR-0035):
    CONSOLE → Spring Boot default text pattern, stays for `docker logs` debug.
    OTEL    → OpenTelemetryAppender pushes OTLP to Alloy, which deterministically
              samples non-error logs at 10% keyed on traceId.
  Test profile keeps Spring Boot's default text pattern for readable test output.
-->
<configuration scan="false">
    <springProfile name="!test">
        <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

        <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
            <captureExperimentalAttributes>true</captureExperimentalAttributes>
            <captureMdcAttributes>traceId,spanId,reservationId,routeId</captureMdcAttributes>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="OTEL"/>
        </root>
    </springProfile>

    <springProfile name="test">
        <include resource="org/springframework/boot/logging/logback/base.xml"/>
    </springProfile>
</configuration>
