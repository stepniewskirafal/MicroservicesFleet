      "panels": [],
      "title": "Outbox Queue (Saturation · Errors · Latency)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Outbox Pending Events (saturation)",
      "description": "Number of rows in event_outbox with status=PENDING. Sustained > 100 = publisher falling behind; > 1000 = cannot keep up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "id": 401,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
