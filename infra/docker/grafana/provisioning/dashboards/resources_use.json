  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "JVM (Utilization · Saturation · Errors)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Heap Utilization (%) by instance",
      "description": "Used / max heap, split per instance — a single instance near OOM is hidden if you sum the whole cluster into one line.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 101,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "100 * sum by (instance, job) (jvm_memory_used_bytes{area=\"heap\", job=~\"$job\"}) / sum by (instance, job) (jvm_memory_max_bytes{area=\"heap\", job=~\"$job\"})",
          "legendFormat": "{{job}} · {{instance}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "GC Pause max [ms] by service",
      "description": "Rolling max GC pause per service from jvm_gc_pause_seconds_max. NOTE: p99 is intentionally not used — jvm.gc.pause has no histogram buckets in this project (histograms are enabled only via distribution.slo:, and jvm.gc.pause is not listed there), so jvm_gc_pause_seconds_bucket does not exist. Micrometer's _max gives a free rolling-max saturation signal.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 102,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto" },
          "unit": "ms"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "1000 * max by (job) (jvm_gc_pause_seconds_max{job=~\"$job\"})",
          "legendFormat": "{{job}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Old-gen Saturation [used / max] by instance",
      "description": "Approaching 1.0 means major GC pressure incoming. Split per instance so a single leaking instance is not averaged away.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 103,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (instance, job) (jvm_memory_used_bytes{id=~\".*Old.*|.*Tenured.*|.*G1 Old.*\", job=~\"$job\"}) / sum by (instance, job) (jvm_memory_max_bytes{id=~\".*Old.*|.*Tenured.*|.*G1 Old.*\", job=~\"$job\"})",
          "legendFormat": "{{job}} · {{instance}}",
          "range": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "panels": [],
      "title": "Concurrency & Pools (HTTP · Hikari)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "HTTP In-Flight Requests (concurrency)",
      "description": "Currently executing HTTP requests per instance (Micrometer http.server.requests.active LongTaskTimer). Replaces Tomcat thread-pool utilization: with virtual threads enabled (ADR-0012) there is no bounded worker pool — tomcat_threads_* report -1 — so request concurrency is the real web-tier saturation signal. Rising concurrency together with rising latency = downstream (DB / Kafka) back-pressure. Baseline ~1 = the in-flight Prometheus scrape itself.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 201,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short",
          "min": 0
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (instance, job) (http_server_requests_active_seconds_count{job=~\"$job\"})",
          "legendFormat": "{{job}} · {{instance}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Hikari Pool Utilization (active / max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 202,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "hikaricp_connections_active{job=~\"$job\"} / hikaricp_connections_max{job=~\"$job\"}",
          "legendFormat": "{{job}} · {{pool}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Hikari Pool Saturation (pending threads waiting for connection)",
      "description": "Any sustained pending thread (> 0) means the pool is exhausted; timeout/s means a borrow attempt gave up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 203,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "thresholdsStyle": { "mode": "line" } },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "hikaricp_connections_pending{job=~\"$job\"}",
          "legendFormat": "{{job}} · {{pool}}",
          "range": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "rate(hikaricp_connections_timeout_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "timeout/s · {{job}} · {{pool}}",
          "range": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "panels": [],
      "title": "Kafka (Consumer · Producer)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Consumer Records Lag (max per partition)",
      "description": "How far behind the consumer is. Sustained > 10000 = consumer not keeping up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 301,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "thresholdsStyle": { "mode": "line" } },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "max by (job, client_id, topic) (kafka_consumer_fetch_manager_records_lag_max{job=~\"$job\"})",
          "legendFormat": "{{job}} · {{topic}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Producer Record Queue Time (avg) [ms]",
      "description": "Time records spend buffered in the producer before being sent. Rising = broker slow / network slow.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 302,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "ms"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "max by (job, client_id) (kafka_producer_record_queue_time_avg{job=~\"$job\"})",
          "legendFormat": "{{job}} · {{client_id}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Producer Errors (record send errors / s)",
      "description": "Any non-zero rate is bad — line turns red above 0.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 303,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "auto", "thresholdsStyle": { "mode": "line" } },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.0001 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (job) (rate(kafka_producer_record_error_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{job}}",
          "range": true
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Producer Buffer Available [bytes]",
      "description": "Free buffer space in the producer. Approaching 0 = producer back-pressured.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 304,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" },
          "unit": "bytes"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "min by (job, client_id) (kafka_producer_buffer_available_bytes{job=~\"$job\"})",
          "legendFormat": "{{job}} · {{client_id}}",
          "range": true
        }
      ]
    },
    {
