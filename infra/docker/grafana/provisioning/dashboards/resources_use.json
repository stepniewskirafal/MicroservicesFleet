    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "title": "Outbox Pending Events (saturation)",
      "description": "Number of rows in event_outbox with status=PENDING. Sustained > 1000 = publisher cannot keep up.",
