      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "editorMode": "code",
          "expr": "(((1 - (sum(increase(http_server_requests_seconds_count{job=~\"$job\",status=~\"5..\"}[30d])) / clamp_min(sum(increase(http_server_requests_seconds_count{job=~\"$job\"}[30d])), 1))) * 100) - $slo) / (100 - $slo) * 100",
          "legendFormat": "budget left",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
