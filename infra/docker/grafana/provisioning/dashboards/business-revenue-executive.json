    {
      "id": 4,
      "type": "bargauge",
      "title": "Wskaźnik odrzuceń rezerwacji per klasa — utracona konwersja",
      "description": "Odsetek prób rezerwacji zakończonych odmową (outcome != confirmed: no_capacity / route_unavailable / error) zamiast zatwierdzeniem, per klasa statku, w wybranym okresie. Wysoki słupek = tracimy klientów tej klasy → decyzja: dosypać pojemność / przekierować ruch. Dominującą przyczyną zwykle jest 'no_capacity' — skorelowane z gauge zajętości doków poniżej. Zielony <10%, pomarańczowy 10–25%, czerwony >25%.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 10 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum by (shipClass) (increase(reservations_total{outcome!=\"confirmed\"}[$__range])) / clamp_min(sum by (shipClass) (increase(reservations_total[$__range])), 1)",
          "instant": true,
          "range": false,
          "format": "time_series",
          "legendFormat": "{{shipClass}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "noValue": "0",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 0.1 },
              { "color": "#f43f5e", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "minVizWidth": 0,
        "minVizHeight": 16,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },

