    {
      "id": 6,
      "type": "gauge",
      "title": "Zajętość doków per port — TERAZ (czerwone: <50% pustka / >97% brak miejsca)",
      "description": "Bieżąca zajętość doków. Niska (<50%) = puste doki = utracony przychód. Bardzo wysoka (>97%) = brak miejsca na nowe rezerwacje = też utracony przychód i ryzyko overbookingu. Optymalne pasmo 50–90% (zielone). Jeśli 'brak danych' — przebuduj/zrestartuj starport-registry (DockOccupancyObserver).",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 12 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "max by (starport) (reservations_docks_occupied_ratio)",
          "instant": true,
          "range": false,
          "format": "time_series",
          "legendFormat": "{{starport}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "min": 0,
          "max": 1,
          "noValue": "brak danych",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#f43f5e", "value": null },
              { "color": "#10b981", "value": 0.5 },
              { "color": "#f59e0b", "value": 0.9 },
              { "color": "#f43f5e", "value": 0.97 }
            ]
          }
        },
        "overrides": []
