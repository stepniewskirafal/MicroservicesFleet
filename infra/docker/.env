COMPOSE_PROJECT_NAME=microservices_fleet

# MinIO / Thanos object storage (DEV ONLY — prod: IAM / secret-manager).
# Jedno źródło prawdy: minio czyta MINIO_ROOT_*, a kontenery thanos-* dostają
# te same wartości jako AWS_ACCESS_KEY_ID/SECRET (objstore.yml ma puste klucze).
MINIO_ROOT_USER=minio
